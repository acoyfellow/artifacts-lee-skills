{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["@cloudflare/workers-types", "node"]
	},
	"include": ["src/**/*.ts", "demo/**/*.ts", "worker-configuration.d.ts"]
}
